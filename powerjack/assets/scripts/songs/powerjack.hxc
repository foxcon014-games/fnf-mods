class Powerjack extends Song {

	var game;
	var dad;
	var bf;
	var gf;
	var grayNum:Float = 0;
	var grays:Grayscale = new Grayscale();
	var hudLives:Int;

	var camBars:FunkinCamera;
	var fight1:Bool;
	var fight2:Bool;
	var fight3:Bool;

	var crazy:Bool;
	var adjustColor:FlxRuntimeShader;


	public function new() {
		super('powerjack');
	}

	function onCreate(event) {
		super.onCreate(event);

		game = PlayState.instance;
		dad = game.currentStage.getDad();
		bf = game.currentStage.getBoyfriend();
		gf = game.currentStage.getGirlfriend();
		stage = PlayState.instance.currentStage;

		game.opponentStrumline.x -= 10000;
		game.scoreText.angle = -30;
		game.scoreText.x = game.scoreText.x - 460;
		game.scoreText.y = game.scoreText.y - 50;
		// game.scoreText.visible = false;

		//sorry im too lazy tp fix this in mobile :/


		var grayShaderFilter:ShaderFilter = new ShaderFilter(grays);
		adjustColor = new FlxRuntimeShader(Assets.getText(Paths.frag('adjustColor')));
    adjustColor.setFloat('strength', 0); // 0.2

    PlayState.instance.camGame.filters = [grayShaderFilter, new ShaderFilter(adjustColor)];

		grays.setFloat("_amount", grayNum);


		game.camGame.alpha = 0;
		game.camHUD.alpha = 1;
		game.iconP1.alpha = 0;
		game.healthBar.alpha = 0;
		game.healthBarBG.alpha = 0;

		camBars = new FunkinCamera('playStatecamBars');
		camBars.alpha = 1;
		camBars.bgColor = 0x000000;

	  camComic = new FunkinCamera('camComic');
		camComic.alpha = 1;
		camComic.bgColor = 0x000000;


		// FlxG.cameras.remove(PlayState.instance.camGame, false);
		FlxG.cameras.remove(PlayState.instance.camHUD, false);
		FlxG.cameras.remove(PlayState.instance.camCutscene, false);

		// FlxG.cameras.add(PlayState.instance.camGame, true);
    FlxG.cameras.add(camBars, false);
    FlxG.cameras.add(camComic, false);
		FlxG.cameras.add(PlayState.instance.camHUD, false);
		FlxG.cameras.add(PlayState.instance.camCutscene, false);

		topBar = new FunkinSprite(0, -FlxG.height); //1950
    topBar.makeSolidColor(FlxG.width, FlxG.height, 0xFF000000);
    topBar.cameras = [camBars];
		topBar.alpha = 1;
    topBar.zIndex = -1;
    game.add(topBar);

    downBar = new FunkinSprite(0, 720); //670
    downBar.makeSolidColor(FlxG.width, FlxG.height, 0xFF000000);
    downBar.cameras = [camBars];
    downBar.zIndex = -1;
		downBar.alpha = 1;
    game.add(downBar);

		smoke = new FlxSprite(290,350);
		smoke.frames = Paths.getSparrowAtlas("stages/powerjack/smoke");
		smoke.animation.addByPrefix("idle", "smoke0", 24);
		smoke.antialiasing = true;
		smoke.scale.set(1.3,1.3);
		smoke.animation.play("idle");
		smoke.alpha = 0.00001;
		// stage.insert(stage.members.indexOf(stage.getNamedProp("perspective2")) - 1, smoke);
		game.add(smoke);

		healthBarNew = new FlxSprite(160,FlxG.height * 0.67);
		healthBarNew.frames = Paths.getSparrowAtlas('hud/bar');
		healthBarNew.animation.addByPrefix('heal0','health00000',1, false);
		healthBarNew.animation.addByPrefix('heal1','health10000',1, false);
		healthBarNew.animation.addByPrefix('heal2','health20000',1, false);
		healthBarNew.animation.addByPrefix('heal3','health30000',1, false);
		healthBarNew.animation.addByPrefix('heal4','health40000',1, false);
		healthBarNew.angle = -10;
		healthBarNew.cameras = [game.camHUD];
		healthBarNew.animation.play('heal0');
		healthBarNew.scale.set(0.8,0.8);
		game.add(healthBarNew);

		diamond = new FlxSprite(healthBarNew.x - 285,healthBarNew.y - 180);
		diamond.frames = Paths.getSparrowAtlas('hud/main');
		diamond.animation.addByPrefix('Normal','Normal',24, true);
		diamond.angle = -10;
		diamond.cameras = [game.camHUD];
		diamond.animation.play('Normal');
		diamond.scale.set(0.8,0.8);
		game.add(diamond);

		// if(FlxG.random.bool(5))
		// {
		// PlayState.instance.currentStage.getDad().color = 0xFF0000FF;
		// PlayState.instance.currentStage.getBoyfriend().color = 0xFFFFFF00;

		// PlayState.instance.currentStage.getNamedProp("sky").color = 0xFF0000FF;
		// PlayState.instance.currentStage.getNamedProp("bg1").color = 0xFF0000FF;
		// PlayState.instance.currentStage.getNamedProp("bg2").color = 0xFF0000FF;
		// PlayState.instance.currentStage.getNamedProp("bg3").color = 0xFF0000FF;
		// PlayState.instance.currentStage.getNamedProp("bg4").color = 0xFF0000FF;
		// PlayState.instance.currentStage.getNamedProp("bg5").color = 0xFF0000FF;
		// PlayState.instance.currentStage.getNamedProp("ojos").alpha = 0.8;
		// PlayState.instance.currentStage.getNamedProp("ojos2").alpha = 0.8;

    //     crazy = true;
		// }

		//comic

		// gradient = new FunkinSprite(-800,-3600).loadTexture('stages/powerjack/gradient');
		// gradient.scale.set(10,10);
		// gradient.antialiasing = true;
		// gradient.blend = 1;
		// gradient.alpha = 0.4;

		// gradient.x -= 500;
		// stage.insert(stage.members.indexOf(stage.getNamedProp("bg5") - 1), gradient);


		transition = new FunkinSprite(0, -157).loadGraphic(Paths.image('stages/powerjack/comic/transition'));
		transition.antialiasing = true;
		transition.cameras = [camComic];
		transition.scale.set(0.5,0.5);
		transition.screenCenter();
		transition.y += 700;
		game.add(transition);

		comicbg = new FlxSprite(0,0).makeGraphic(FlxG.width, FlxG.height, 0xFFFFFFFF);
		comicbg.color = 0xe3c4ca;
   	comicbg.scale.set(4, 4);
		comicbg.cameras = [camComic];
		comicbg.visible = false;
		comicbg.scrollFactor.set(0,0);
		comicbg.updateHitbox();
   	comicbg.screenCenter();
		comicbg.x += 100;
    game.add(comicbg);

		comic1 = new FunkinSprite(-756, -157).loadGraphic(Paths.image('stages/powerjack/comic/comic1'));
		comic1.updateHitbox();
		comic1.screenCenter();
		comic1.cameras = [camComic];
		comic1.visible = false;
		comic1.antialiasing = true;
		game.add(comic1);

		comic3 = new FlxSprite().loadGraphic(Paths.image('stages/powerjack/comic/comic3'));
		comic3.updateHitbox();
		comic3.screenCenter();
		comic3.cameras = [camComic];
		comic3.visible = false;
		comic3.antialiasing = true;
		game.add(comic3);

		comic2 = new FlxSprite().loadGraphic(Paths.image('stages/powerjack/comic/comic2'));
		comic2.updateHitbox();
		comic2.screenCenter();
		comic2.cameras = [camComic];
		comic2.visible = false;
		comic2.antialiasing = true;
		game.add(comic2);

		comic = new FlxSprite().loadGraphic(Paths.image('stages/powerjack/comic/comic'));
		comic.updateHitbox();
		comic.screenCenter();
		comic.cameras = [camComic];
		comic.visible = false;
		comic.antialiasing = true;
		game.add(comic);
	}

	function onSongRetry(event){
		super.onSongRetry(event);

        game.camGame.alpha = 0;
				game.camHUD.alpha = 1;
				camBars.alpha = 1;
				camComic.alpha = 1;
				game.iconP1.alpha = 0;
				game.healthBar.alpha = 0;
				game.healthBarBG.alpha = 0;
				fight1 = true;
				fight2 = false;
				fight3 = false;
				topBar.y = -FlxG.height;
				downBar.y = FlxG.height;
				grayNum = 0;
				comic.visible = false;
				comic1.visible = false;
				comic2.visible = false;
				comic3.visible = false;
				comic.screenCenter();
				comic1.screenCenter();
				comic2.screenCenter();
				comic3.screenCenter();
				transition.screenCenter();
				transition.y += 700;
				camComic.scroll.x = 0;
				camComic.scroll.y = 0;
				camComic.zoom = 1;
				for (pizza in [game.iconP2, healthBarNew, game.scoreText, diamond])
			  {
					pizza.alpha = 1;
			  }
				for (fight in [PlayState.instance.currentStage.getNamedProp("perspective2"), PlayState.instance.currentStage.getNamedProp("bgFight")])
				{
					fight.alpha = 0;
				}
				for (fightbye in [PlayState.instance.currentStage.getNamedProp("sky"), PlayState.instance.currentStage.getNamedProp("bg1"), PlayState.instance.currentStage.getNamedProp("bg2"),  PlayState.instance.currentStage.getNamedProp("bg3"),  PlayState.instance.currentStage.getNamedProp("bg4"),  PlayState.instance.currentStage.getNamedProp("bg5") ])
				{
					fightbye.alpha = 1;
				}
				PlayState.instance.currentStage.getNamedProp("skyp3").alpha = 0;
				PlayState.instance.currentStage.getNamedProp("cloud").alpha = 0;
				PlayState.instance.currentStage.getNamedProp("clouds").alpha = 0;
				PlayState.instance.currentStage.getNamedProp("stagep3").alpha = 0;
				PlayState.instance.currentStage.getNamedProp("aura").alpha = 0;
	}

	 function onSongLoaded(e:Dynamic)
    {
			super.onSongLoaded(e);

			ModuleHandler.getModule('CamMovement').scriptCall('initCamMovement');
			fight1 = true;
			fight2 = false;
			fight3 = false;
	}



	function onSongStart(e:Dynamic)
  {
      super.onSongStart(e);
	}


	public override function onUpdate(event) {
		super.onUpdate(event);

		// if(crazy)
		// {
		//   PlayState.instance.currentStage.getDad().y -= 0.1;

		//   PlayState.instance.currentStage.getDad().scale.y += 0.0001;
		//   PlayState.instance.currentStage.getNamedProp("ojos").y -= 0.1;
		// }

		game.iconP2.autoUpdate = false;
      game.iconP2.setPosition(100, game.healthBarBG.y + (game.healthBarBG.height / 2) - 100 - (game.iconP2.height / 2));


		if (grays != null)
			grays.setFloat("_amount", grayNum);



	}






	public override function onCountdownStart(event) {

   // FlxTimer.wait(0.01, () -> Countdown.skipCountdown());

	}





   function onStepHit(event:SongTimeScriptEvent):Void {
    super.onStepHit(event);
    curStep = event.step;


    switch (curStep) {


	case 1:
		game.camCutscene.flash(0xFFFF0000, 0.4);

	case 4:
		game.camHUD.flash(0xFFFF0000, 0.4);

	case 8:
		game.camCutscene.flash(0xFFFF0000, 0.4);

	case 12:
		game.camHUD.flash(0xFFFF0000, 0.4);


	case 16:
		FlxTween.tween(topBar, {y: topBar.y + 50}, 2, {ease: FlxEase.cubeInOut});
		FlxTween.tween(downBar, {y: downBar.y - 50}, 2, {ease: FlxEase.cubeInOut});
		game.camGame.alpha = 1;
		game.camGame.flash(0xFFFFFFFF, 1);
		FlxTween.tween(game.camHUD, {alpha: 0}, 1);
		smoke.alpha = 1;

	case 40:
	    game.camGame.alpha = 1;

	case 273:
		FlxTween.tween(topBar, {y: topBar.y + 75}, 2, {ease: FlxEase.cubeInOut});
		FlxTween.tween(downBar, {y: downBar.y - 75}, 2, {ease: FlxEase.cubeInOut});

	case 304:
		FlxTween.tween(game.camHUD, {alpha: 1}, 5);
        FlxTween.tween(topBar, {y: topBar.y - 125}, 4, {ease: FlxEase.cubeInOut});
		FlxTween.tween(downBar, {y: downBar.y + 125}, 4, {ease: FlxEase.cubeInOut});

	case 528:
	    FlxTween.tween(game, {currentCameraZoom: 0.8}, 2, {ease: FlxEase.cubeInOut});
		FlxTween.tween(topBar, {y: topBar.y + 125}, 2, {ease: FlxEase.cubeInOut});
		FlxTween.tween(downBar, {y: downBar.y - 125}, 2, {ease: FlxEase.cubeInOut});

	case 560:
	    FlxTween.tween(game, {currentCameraZoom: 0.5}, 2, {ease: FlxEase.cubeInOut});
		FlxTween.tween(topBar, {y: topBar.y - 125}, 2, {ease: FlxEase.cubeInOut});
		FlxTween.tween(downBar, {y: downBar.y + 125}, 2, {ease: FlxEase.cubeInOut});

	case 832:
	    FlxTween.tween(topBar, {y: topBar.y + 50}, 2, {ease: FlxEase.cubeInOut});
		FlxTween.tween(downBar, {y: downBar.y - 50}, 2, {ease: FlxEase.cubeInOut});
		FlxTween.num(grayNum, 1, 1.5, {}, function(v:Float) {
           grayNum = v;
        });

	case 880:
		FlxTween.tween(topBar, {y: topBar.y - 75}, 4, {ease: FlxEase.cubeInOut});
		FlxTween.tween(downBar, {y: downBar.y + 75}, 4, {ease: FlxEase.cubeInOut});
		FlxTween.num(grayNum, 0, 1.5, {}, function(v:Float) {
           grayNum = v;
        });

	case 1036:
		 for (pizza in [game.iconP2, healthBarNew, game.scoreText, diamond])
			 {
			FlxTween.tween(pizza, {alpha: 0}, 1);

			 }
		FlxTween.tween(topBar, {y: topBar.y + 450}, 2, {ease: FlxEase.cubeInOut});
		FlxTween.tween(downBar, {y: downBar.y - 450}, 2, {ease: FlxEase.cubeInOut});
		fight2 = true;
		fight1 = false;
		fight3 = false;

	case 1056:
		camComic.alpha = 1;
		FlxTween.tween(transition, {y: transition.y - 700}, 2, {ease: FlxEase.cubeOut});

	case 1088:
		FlxTween.tween(transition, {y: transition.y - 700}, 2, {ease: FlxEase.cubeOut, onComplete: function (_) {
			camComic.alpha = 0;
		}});

	case 1096:
	        for (fight in [PlayState.instance.currentStage.getNamedProp("perspective2"), PlayState.instance.currentStage.getNamedProp("bgFight")])
			{
			  fight.alpha = 1;
			}
			for (fightbye in [PlayState.instance.currentStage.getNamedProp("sky"), PlayState.instance.currentStage.getNamedProp("bg1"), PlayState.instance.currentStage.getNamedProp("bg2"),  PlayState.instance.currentStage.getNamedProp("bg3"),  PlayState.instance.currentStage.getNamedProp("bg4"),  PlayState.instance.currentStage.getNamedProp("bg5") ])
			{
			  fightbye.alpha = 0;
			}
			FlxTween.tween(topBar, {y: topBar.y - 390}, 2, {ease: FlxEase.cubeInOut});
		    FlxTween.tween(downBar, {y: downBar.y + 390}, 2, {ease: FlxEase.cubeInOut});

	case 1240:
		FlxTween.num(grayNum, 1, 1, {}, function(v:Float) {
           grayNum = v;
        });

	case 1264:
			FlxTween.num(grayNum, 0, 1, {}, function(v:Float) {
           grayNum = v;
        });

	case 1400:
		FlxTween.tween(topBar, {y: topBar.y + 390}, 2, {ease: FlxEase.quadInOut});
		FlxTween.tween(downBar, {y: downBar.y - 390}, 2, {ease: FlxEase.quadInOut});
		FlxTween.tween(game.camHUD, {alpha: 0}, 2, {ease: FlxEase.quadInOut});

		case 1416:
			smoke.alpha = 0;
			camComic.alpha = 1;
      comic.visible = true;
			comic1.visible = true;
			comic2.visible = true;
			comic3.visible = true;

			comic.setPosition(0, 0);
			comic1.setPosition(0, 0);
			comic2.setPosition(0, 0);
			comic3.setPosition(0, 0);
			comic2.alpha = 0;
			FlxTween.tween(comic2, {alpha: 1}, 2, {ease: FlxEase.cubeOut});
			FlxTween.tween(camComic.scroll, {x: 0, y: 100}, 0.5, {ease: FlxEase.cubeOut});

		case 1448:
			FlxTween.tween(camComic.scroll, {x: 1100, y: 100}, 0.5, {ease: FlxEase.cubeOut});
			FlxTween.tween(game.camHUD, {alpha: 1}, 2, {ease: FlxEase.quadInOut});
			 for (kosako in [game.iconP2, healthBarNew, game.scoreText, diamond])
			 {
			FlxTween.tween(kosako, {alpha: 1}, 1);

			 }

		case 1472:
			FlxTween.tween(camComic.scroll, {x: 0, y: 800}, 0.5, {ease: FlxEase.cubeOut});
		case 1480:
			FlxTween.tween(camComic.scroll, {x: 800, y: 800}, 0.5, {ease: FlxEase.cubeOut});
		case 1496:
			FlxTween.tween(camComic.scroll, {x: 500, y: 1750}, 0.5, {ease: FlxEase.cubeOut});
			FlxTween.tween(camComic, {zoom: 0.6}, 0.5, {ease: FlxEase.cubeOut});


		case 1512:
			FlxTween.tween(topBar, {y: topBar.y - 450}, 0.1, {ease: FlxEase.quadInOut});
		  FlxTween.tween(downBar, {y: downBar.y + 450}, 0.1, {ease: FlxEase.quadInOut});
			FlxTween.tween(camComic, {zoom: 5}, 4, {ease: FlxEase.cubeOut});
			FlxTween.tween(comic1, {alpha: 0}, 0.5, {ease: FlxEase.cubeOut});
			FlxTween.tween(comic2, {alpha: 0}, 0.5, {ease: FlxEase.cubeOut});
			FlxTween.tween(comic3, {alpha: 0}, 0.5, {ease: FlxEase.cubeOut});
			PlayState.instance.currentStage.getNamedProp("aura").alpha = 1;
			PlayState.instance.currentStage.getNamedProp("aura").blend = 0;

		case 1576:
			FlxTween.tween(topBar, {y: topBar.y + 70}, 2, {ease: FlxEase.quadInOut});
		    FlxTween.tween(downBar, {y: downBar.y - 70}, 2, {ease: FlxEase.quadInOut});

		case 1424:

		    PlayState.instance.currentStage.getBoyfriend().color = 0xFF000000;

			fight3 = true;
			fight2 = false;
			fight1 = false;
			PlayState.instance.currentStage.getNamedProp("skyp3").alpha = 1;
			PlayState.instance.currentStage.getNamedProp("cloud").alpha = 1;
			PlayState.instance.currentStage.getNamedProp("clouds").alpha = 1;
			PlayState.instance.currentStage.getNamedProp("stagep3").alpha = 1;
			PlayState.instance.currentStage.getNamedProp("perspective2").alpha = 0;



			for (fightbye in [PlayState.instance.currentStage.getNamedProp("sky"), PlayState.instance.currentStage.getNamedProp("bg1"), PlayState.instance.currentStage.getNamedProp("bg2"),  PlayState.instance.currentStage.getNamedProp("bg3"),  PlayState.instance.currentStage.getNamedProp("bg4"),  PlayState.instance.currentStage.getNamedProp("bg5") ])
			{
			  fightbye.alpha = 0;
			}

		case 1600:
			 FlxTween.color(PlayState.instance.currentStage.getBoyfriend(), 2,  0xFF000000, 0xFFFFFFFF, {ease: FlxEase.quadInOut});
			 FlxTween.tween(PlayState.instance.currentStage.getNamedProp("cloud"), {alpha: 0}, 1);

		case 1848:
			FlxTween.num(grayNum, 1, 2, {}, function(v:Float) {
           grayNum = v;
        });

		case 1864:
			game.camGame.alpha = 0;
			game.camHUD.alpha = 0;
			FlxTween.tween(topBar, {y: topBar.y + 390}, 2, {ease: FlxEase.cubeInOut});
		    FlxTween.tween(downBar, {y: downBar.y - 390}, 2, {ease: FlxEase.cubeInOut});

		case 1912:
		game.camCutscene.flash(0xFFFF0000, 0.4);

		case 1920:
		game.camCutscene.flash(0xFFFF0000, 0.4);

		case 1944:
		game.camCutscene.flash(0xFFFF0000, 0.4);

		case 1952:
		game.camCutscene.flash(0xFFFF0000, 0.4);

		case 1976:
		game.camCutscene.flash(0xFFFF0000, 0.4);
		game.camGame.alpha = 1;
		FlxTween.tween(game.camHUD, {alpha: 1}, 3);
		FlxTween.num(grayNum, 0, 0.2, {}, function(v:Float) {
           grayNum = v;
        });

		FlxTween.tween(topBar, {y: topBar.y - 390}, 2, {ease: FlxEase.cubeInOut});
		FlxTween.tween(downBar, {y: downBar.y + 390}, 2, {ease: FlxEase.cubeInOut});

		case 1984:
		game.camCutscene.flash(0xFFFF0000, 0.4);

		case 2248:
		game.camGame.alpha = 0;


	}
   }



	function onBeatHit(event) {
		super.onBeatHit(event);
		curBeat = event.beat;

		// trace(game.health);

		if (game.health >= 0.2)
			healthBarNew.animation.play('heal0');
		if (game.health >= 0.6)
			healthBarNew.animation.play('heal1');
		if (game.health >= 1)
			healthBarNew.animation.play('heal2');
		if (game.health >= 1.4)
			healthBarNew.animation.play('heal3');
		if (game.health >= 1.9)
			healthBarNew.animation.play('heal4');

		switch (event.beat) {

		//tremenda cagada de code no supe hacer los flashes bien xddddddddddddddddd

    case 256:
		game.camGame.flash(0xFFFFFFFF, 0.4);

		case 257:
		game.camHUD.flash(0xFFFFFFFF, 0.4);

		case 258:
		game.camGame.flash(0xFFFFFFFF, 0.4);

		case 259:
		game.camHUD.flash(0xFFFFFFFF, 0.4);

		case 479:
		camBars.flash(0xFFFF0000, 0.4);

		case 481:
		camBars.flash(0xFFFF0000, 0.4);

		case 487:
		camBars.flash(0xFFFF0000, 0.4);

		case 489:
		camBars.flash(0xFFFF0000, 0.4);

		case 495:
		camBars.flash(0xFFFF0000, 0.4);

		case 497:
		camBars.flash(0xFFFF0000, 0.4);


		}
	}


	public override function onSongEvent(scriptEvent:SongEventScriptEvent)
	{
		super.onSongEvent(scriptEvent);

		if (scriptEvent.eventData.eventKind == "FocusCamera")
		{
				var eventProps = scriptEvent.eventData.value;

				if (fight1)
				{
					switch (Std.parseInt(eventProps.char)) {
						case 0:
									FlxTween.tween(game, {currentCameraZoom: 0.5}, 1, {ease: FlxEase.cubeOut});
						case 1:
									FlxTween.tween(game, {currentCameraZoom: 1}, 1, {ease: FlxEase.cubeOut});
						default:
					}
				}
				if (fight2)
				{
					fight1 = false;
					fight3 = false;
					switch (Std.parseInt(eventProps.char)) {
						case 0:
									FlxTween.tween(game, {currentCameraZoom: 0.95}, 1, {ease: FlxEase.cubeOut});
						case 1:
									FlxTween.tween(game, {currentCameraZoom: 0.95}, 1, {ease: FlxEase.cubeOut});
						default:
					}
				}

				if (fight3)
				{
					fight1 = false;
					fight2 = false;
					switch (Std.parseInt(eventProps.char)) {
						case 0:
									FlxTween.tween(game, {currentCameraZoom: 1}, 1, {ease: FlxEase.cubeOut});
						case 1:
									FlxTween.tween(game, {currentCameraZoom: 0.5}, 1, {ease: FlxEase.cubeOut});
						default:
					}

				}
		}
	}






